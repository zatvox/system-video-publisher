# ZV Publicidad Digital — Variables de entorno (referencia)
#
# Este archivo NO se usa en producción directamente.
# Las credenciales van en assets/js/config.js
#
# NUNCA subas config.js con credenciales reales a un repo público.
# Para GitHub Pages públicos el anon key es seguro de exponer
# porque Supabase RLS controla el acceso a nivel de fila.

# ─── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Negocio ────────────────────────────────────────────
# Estos valores se gestionan desde el panel admin → Planes → Configuración
# y se almacenan en la tabla configuracion_negocio de Supabase.

NOMBRE_NEGOCIO=ZV Publicidad Digital
BANCO_NOMBRE=BCP
BANCO_CUENTA=
BANCO_CCI=
BANCO_TITULAR=
WHATSAPP=51999999999
HORARIO_INICIO=08:00
HORARIO_FIN=19:00
